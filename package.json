{
  "name": "apps",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Paperclip apps monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/hello",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present -- --run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.20.0"
  }
}
